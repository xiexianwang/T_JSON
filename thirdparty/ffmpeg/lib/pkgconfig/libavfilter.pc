prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 11.17.100
Requires: 
Requires.private: libswscale >= 9.7.100, libavformat >= 62.19.100, libavcodec >= 62.35.100, libswresample >= 6.4.100, libavutil >= 60.31.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Cflags: -I${includedir}
